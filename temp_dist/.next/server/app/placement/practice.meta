{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/placement/layout,_N_T_/placement/practice/layout,_N_T_/placement/practice/page,_N_T_/placement/practice"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/placement/practice/__PAGE__",
    "/placement/practice",
    "/placement",
    "/_index",
    "/_head"
  ]
}