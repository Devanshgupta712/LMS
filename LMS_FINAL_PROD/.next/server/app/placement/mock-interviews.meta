{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/placement/layout,_N_T_/placement/mock-interviews/layout,_N_T_/placement/mock-interviews/page,_N_T_/placement/mock-interviews"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/placement/mock-interviews/__PAGE__",
    "/placement/mock-interviews",
    "/placement",
    "/_index",
    "/_head"
  ]
}